# Coordinator binding
PSI_COORDINATOR_HOST=127.0.0.1
PSI_COORDINATOR_PORT=8080

# Temporary API keys
PSI_COORDINATOR_ADMIN_API_KEY=replace-admin-key
PSI_COORDINATOR_PARTY_A_API_KEY=replace-party-a-key
PSI_COORDINATOR_PARTY_B_API_KEY=replace-party-b-key

# Runtime limits
PSI_COORDINATOR_VALIDATE_TIMEOUT_SECONDS=30
PSI_COORDINATOR_RUN_TIMEOUT_SECONDS=300
PSI_COORDINATOR_VERIFY_TIMEOUT_SECONDS=30
PSI_COORDINATOR_ARCHIVE_TIMEOUT_SECONDS=30
PSI_COORDINATOR_RATE_LIMIT_WINDOW_SECONDS=60
PSI_COORDINATOR_RATE_LIMIT_MAX_REQUESTS=300
